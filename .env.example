# Active data backend: airtable | sheets
DATA_BACKEND=airtable

# Airtable
AIRTABLE_BASE_ID=app_xxxxxxxxxxxxx
AIRTABLE_API_KEY=pat_xxxxxxxxxxxxx
AIRTABLE_TABLE_REQUESTS=Requests
AIRTABLE_TABLE_ACTIVE_ACCESS=ActiveAccess
AIRTABLE_TABLE_REFERENCE=ReferenceHierarchy
AIRTABLE_TABLE_ADMINS=AdminUsers
AIRTABLE_TABLE_SETTINGS=AdminSettings
AIRTABLE_TABLE_DELETED_REQUESTS=DeletedRequests
AIRTABLE_TABLE_DELETED_ACTIVE_ACCESS=DeletedActiveAccess
AIRTABLE_TABLE_ACCESS_OTP=AccessOtp
AIRTABLE_TABLE_LOGIN_AUDIT=LoginAudit

# Google Sheets
# Use one of the following:
# 1) GOOGLE_SERVICE_ACCOUNT_KEYFILE (local dev)
# 2) GOOGLE_SERVICE_ACCOUNT_JSON (deploy; raw JSON or base64)
GOOGLE_SERVICE_ACCOUNT_KEYFILE=/Users/janghyuk.suh/Documents/New project/credentials/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=your_service_account_json_or_base64
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEETS_OWNER_EMAIL=digitalproductionsquad@gmail.com
GS_SHEET_REQUESTS=Requests
GS_SHEET_ACTIVE_ACCESS=ActiveAccess
GS_SHEET_REFERENCE=ReferenceHierarchy
GS_SHEET_ADMINS=AdminUsers
GS_SHEET_SETTINGS=AdminSettings
GS_SHEET_ACCESS_OTP=AccessOtp
GS_SHEET_LOGIN_AUDIT=LoginAudit

# Admin password (protects admin endpoints)
ADMIN_PASSWORD=replace_with_strong_password

# Optional: portal password (protects entire site)
# If omitted, ADMIN_PASSWORD is used instead.
SITE_PASSWORD=replace_with_portal_password

# SMTP (Gmail or corporate SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=digitalproductionsquad@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=digitalproductionsquad@gmail.com

# Public URL for email images (optional)
PUBLIC_BASE_URL=https://lgecreativehub.vercel.app
